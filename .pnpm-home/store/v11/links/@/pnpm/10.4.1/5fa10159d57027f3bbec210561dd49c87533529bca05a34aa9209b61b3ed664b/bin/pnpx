#!/bin/sh
basedir=$(dirname "$(echo "$0" | sed -e 's,\\,/,g')")

case `uname` in
    *CYGWIN*|*MINGW*|*MSYS*)
        if command -v cygpath > /dev/null 2>&1; then
            basedir=`cygpath -w "$basedir"`
        fi
    ;;
esac

if [ -x "$basedir/node" ]; then
  exec "$basedir/node"  "$basedir/../node_modules/pnpm/bin/pnpx.cjs" "$@"
else
  exec node  "$basedir/../node_modules/pnpm/bin/pnpx.cjs" "$@"
fi
# cmd-shim-target=/Users/titiwat/Downloads/anime-agents/.pnpm-home/store/v11/links/@/pnpm/10.4.1/5fa10159d57027f3bbec210561dd49c87533529bca05a34aa9209b61b3ed664b/node_modules/pnpm/bin/pnpx.cjs
